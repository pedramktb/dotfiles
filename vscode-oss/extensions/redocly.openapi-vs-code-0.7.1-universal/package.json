{
	"name": "openapi-vs-code",
	"displayName": "Redocly OpenAPI",
	"description": "",
	"author": "Redocly Inc <team@redocly.com>",
	"version": "0.7.1",
	"publisher": "Redocly",
	"repository": {
		"type": "git",
		"url": "https://github.com/Redocly/redocly-vs-code"
	},
	"categories": [
		"Programming Languages",
		"Snippets",
		"Linters",
		"Other"
	],
	"engines": {
		"vscode": "^1.43.0"
	},
	"activationEvents": [
		"workspaceContains:redocly.yaml",
		"onLanguage:yaml",
		"onLanguage:json",
		"onCommand:RedoclyOpenAPI.openPreview",
		"onCommand:RedoclyOpenAPI.openContext"
	],
	"main": "./out/client/src/extension",
	"icon": "icon.png",
	"keywords": [
		"openapi",
		"redoc",
		"redocly",
		"swagger",
		"json",
		"yaml",
		"api"
	],
	"contributes": {
		"commands": [
			{
				"command": "RedoclyOpenAPI.openPreview",
				"title": "Open preview",
				"category": "Redocly OpenAPI",
				"enablement": "editorLangId == yaml || editorLangId == json",
				"icon": {
					"light": "./out/webview/icons/redocly-light.svg",
					"dark": "./out/webview/icons/redocly-dark.svg"
				}
			},
			{
				"command": "RedoclyOpenAPI.openContext",
				"title": "Open cursor context",
				"category": "Redocly OpenAPI",
				"enablement": "editorLangId == yaml",
				"icon": {
					"light": "./out/webview/icons/openapi-light.svg",
					"dark": "./out/webview/icons/openapi-dark.svg"
				}
			}
		],
		"menus": {
			"editor/title": [
				{
					"when": "editorLangId == yaml  || editorLangId == json",
					"command": "RedoclyOpenAPI.openPreview",
					"group": "navigation"
				},
				{
					"when": "editorLangId == yaml",
					"command": "RedoclyOpenAPI.openContext",
					"group": "navigation"
				}
			]
		},
		"configuration": {
			"type": "object",
			"title": "Redocly OpenAPI",
			"properties": {
				"redoclyOpenAPI.user.anonymousId": {
					"scope": "window",
					"type": "string",
					"description": "Anonymous id for preview and cursor context."
				}
			}
		},
		"configurationDefaults": {
			"[yaml]": {
				"editor.insertSpaces": true,
				"editor.tabSize": 2,
				"editor.quickSuggestions": {
					"other": true,
					"comments": false,
					"strings": true
				},
				"editor.autoIndent": "full",
				"editor.wordBasedSuggestions": false
			}
		}
	},
	"scripts": {
		"build": "npm run clean && npm run compile && npm run compile-webview",
		"vscode:prepublish": "npm run build",
		"watch": "concurrently \"npm run -S esbuild-base -- --sourcemap --watch\" \"npm run -S compile-webview:ref-docs -- --sourcemap --watch\" \"npm run -S compile-webview:context -- --sourcemap --watch\"",
		"compile": "npm run -S esbuild-base -- --minify",
		"clean": "rm -rf ./out ./client/out ./server/out ./client/tsconfig.test.tsbuildinfo",
		"pretest:e2e": "npm run build && tsc -p ./client/tsconfig.test.json",
		"test:e2e": "sh ./scripts/e2e.sh",
		"test:cypress": "npm run code-server-up && ./client/node_modules/.bin/cypress run && npm run code-server-down",
		"test:cypress-debug": "npm run code-server-up && ./client/node_modules/.bin/cypress open && npm run code-server-down",
		"test:unit-mocks": "jest --roots __mocks__ __tests__ --preset ts-jest && npm run mock-language-server",
		"test:unit": "npm run test:unit-mocks && jest --projects ./client ./client/webview ./server --coverage",
		"mock-language-server": "esbuild ./node_modules/@redocly/openapi-language-server/lib/index.js --bundle --outdir=./server/src/__mocks__/@redocly/openapi-language-server/ --format=cjs --platform=node && esbuild ./node_modules/@redocly/openapi-core/lib/index.js --bundle --outdir=./client/webview/__mocks__/@redocly/openapi-core/ --format=cjs --platform=node",
		"ts:check": "tsc --noEmit --skipLibCheck",
		"code-server-up": "docker-compose up -d && docker exec vscodeExtension code-server --install-extension /source/test.vsix",
		"code-server-down": "docker-compose down",
		"test": "npm run test:unit && echo OK",
		"esbuild-base": "esbuild ./client/src/extension.ts ./server/src/server.ts --bundle --outdir=out --external:vscode --format=cjs --platform=node --define:process.env.NODE_ENV=\\\"$NODE_ENV\\\"",
		"deploy": "NODE_ENV=production vsce publish --no-dependencies",
		"test-package": "vsce package --out client/cypress/test.vsix --no-dependencies",
		"prod-package": "NODE_ENV=production vsce package --out client/cypress/prod.vsix --no-dependencies",
		"compile-webview": "concurrently \"npm run compile-webview:ref-docs\" \"npm run compile-webview:context\"",
		"postcompile-webview": "cp -r ./client/webview/icons ./out/webview",
		"compile-webview:ref-docs": "esbuild ./client/webview/reference-docs/index.tsx --bundle --outdir=out/webview/reference-docs --format=iife --minify --define:process.env.NODE_ENV=\\\"$NODE_ENV\\\"",
		"postcompile-webview:ref-docs": "cp ./client/webview/reference-docs/redocly-reference-docs.min.js ./out/webview/reference-docs/redocly-reference-docs.min.js",
		"compile-webview:context": "esbuild ./client/webview/explorer/cursor-details/index.tsx --bundle --outdir=out/webview/explorer --format=iife --minify --define:process.env.NODE_ENV=\\\"$NODE_ENV\\\""
	},
	"devDependencies": {
		"@types/glob": "catalog:",
		"@types/jest": "29.5.11",
		"@types/mocha": "catalog:",
		"@types/node": "catalog:",
		"@vscode/vsce": "catalog:",
		"concurrently": "6.5.1",
		"esbuild": "catalog:",
		"glob": "8.1.0",
		"jest": "29.5.0",
		"jest-environment-jsdom": "^29.7.0",
		"mocha": "catalog:",
		"ts-jest": "29.1.2",
		"ts-loader": "catalog:",
		"typescript": "catalog:",
		"webpack-cli": "^5.1.4"
	},
	"dependencies": {
		"@opentelemetry/exporter-trace-otlp-http": "catalog:",
		"@opentelemetry/resources": "catalog:",
		"@opentelemetry/sdk-trace-node": "catalog:",
		"@opentelemetry/semantic-conventions": "catalog:",
		"@redocly/openapi-core": "catalog:",
		"@redocly/openapi-language-server": "workspace:*",
		"@sentry/node": "^6.16.1",
		"node-machine-id": "catalog:"
	},
	"__metadata": {
		"id": "43ac9139-82a5-4580-856a-71792a204014",
		"publisherDisplayName": "Redocly",
